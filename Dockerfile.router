FROM node:22-slim

WORKDIR /app

COPY package.json package-lock.json ./
COPY shared/package.json shared/package.json
COPY yield-router-agent/package.json yield-router-agent/package.json
COPY risk-manager-agent/package.json risk-manager-agent/package.json
COPY signal-aggregator-agent/package.json signal-aggregator-agent/package.json
COPY dashboard/package.json dashboard/package.json
COPY oracle-agent/package.json oracle-agent/package.json
COPY arbitrage-agent/package.json arbitrage-agent/package.json

RUN npm install --legacy-peer-deps

COPY . .

WORKDIR /app/yield-router-agent

CMD ["npx", "tsx", "src/index.ts"]
