# --- Network ---
NETWORK=sepolia

# --- Privy (wallet provider) ---
# Get from https://dashboard.privy.io/ -> your app -> "API keys" tab
# Server-side only — never expose APP_SECRET client-side.
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- ERC-8004 registration (only needed for register-both.ts) ---
# Pinata JWT, from https://app.pinata.cloud/developers/api-keys (free tier: 1GB/500 files)
PINATA_JWT=

# --- x402 mode (mock by default — costs nothing, no thirdweb needed) ---
X402_MODE=mock

# --- thirdweb (only if X402_MODE=thirdweb, costs $99+/mo + 0.3%/tx) ---
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=

# --- yield-router-agent specific (Fase 2) ---
ORACLE_URL=http://localhost:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TRADE_AMOUNT_USDM=10